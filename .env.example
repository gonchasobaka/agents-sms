# Add API keys for whichever providers you want to use.
# At least one is required. Multiple providers = automatic cheapest-first selection.

# 5sim — https://5sim.net
FIVESIM_API_KEY=

# SMS-Activate — https://sms-activate.org
SMSACTIVATE_API_KEY=

# OnlineSim — https://onlinesim.io
ONLINESIM_API_KEY=

# Transport: stdio (default, for local MCP clients) or sse (for remote/HTTP)
# TRANSPORT=stdio

# Port (only used in sse mode)
# PORT=3000

# ── Billing tools (optional) ──────────────────────────────────────────────────
# Required for get_balance and create_invoice tools

# Your backend API URL (where balance/invoices are managed)
# BACKEND_API_URL=https://your-backend.com/api

# API key for the agent to authenticate with your backend
# MCP_SMS_API_KEY=your_api_key_here

# CryptoBot token for creating payment invoices
# Get it from @CryptoBot on Telegram → Apps → Create App
# CRYPTOBOT_TOKEN=
