# Add API keys for whichever providers you want to use.
# At least one is required. Multiple providers = automatic cheapest-first selection.

# 5sim — https://5sim.net
FIVESIM_API_KEY=

# SMS-Activate — https://sms-activate.org
SMSACTIVATE_API_KEY=

# OnlineSim — https://onlinesim.io
ONLINESIM_API_KEY=

# Transport: stdio (default, for local MCP clients) or sse (for remote/HTTP)
# TRANSPORT=stdio

# Port (only used in sse mode)
# PORT=3000
